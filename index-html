        let scene, camera, renderer, particleSystem, starField, waveLines;
        
        function init3D() {
            scene = new THREE.Scene();
            scene.background = null; // transparent for dark bg
            camera = new THREE.PerspectiveCamera(75, window.innerWidth / window.innerHeight, 0.1, 1000);
            renderer = new THREE.WebGLRenderer({ canvas: document.getElementById('bg-canvas'), antialias: true, alpha: true });
            renderer.setSize(window.innerWidth, window.innerHeight);
            renderer.setPixelRatio(window.devicePixelRatio);
            
            // Main glowing particles grid (matrix like)
            const particleCount = 2800;
            const geometry = new THREE.BufferGeometry();
            const positions = new Float32Array(particleCount * 3);
            const colors = new Float32Array(particleCount * 3);
            
            for (let i = 0; i < particleCount; i++) {
                // spread in a sphere but with cylindrical depth
                const radius = 6;
                const theta = Math.random() * Math.PI * 2;
                const phi = Math.acos(2 * Math.random() - 1);
                const x = (Math.random() - 0.5) * 12;
                const y = (Math.random() - 0.5) * 8;
                const z = (Math.random() - 0.5) * 12 - 3;
                positions[i*3] = x;
                positions[i*3+1] = y;
                positions[i*3+2] = z;
                
                const greenIntensity = 0.3 + Math.random() * 0.7;
                colors[i*3] = 0.1;
                colors[i*3+1] = greenIntensity;
                colors[i*3+2] = 0.1;
            }
            geometry.setAttribute('position', new THREE.BufferAttribute(positions, 3));
            geometry.setAttribute('color', new THREE.BufferAttribute(colors, 3));
            
            const particleMat = new THREE.PointsMaterial({ size: 0.045, vertexColors: true, transparent: true, opacity: 0.7, blending: THREE.AdditiveBlending });
            particleSystem = new THREE.Points(geometry, particleMat);
            scene.add(particleSystem);
            
            // additional floating grid lines effect: add a simple wireframe torus knot
            const knotGeo = new THREE.TorusKnotGeometry(1.2, 0.25, 180, 24, 3, 4);
            const knotMat = new THREE.MeshBasicMaterial({ color: 0x00aa33, wireframe: true, transparent: true, opacity: 0.2 });
            const knot = new THREE.Mesh(knotGeo, knotMat);
            knot.position.set(0, 0.5, -2);
            scene.add(knot);
            
            const ringGeo = new THREE.TorusGeometry(1.6, 0.05, 64, 200);
            const ringMat = new THREE.MeshBasicMaterial({ color: 0x00ff66, wireframe: false, transparent: true, opacity: 0.2 });
            const ring = new THREE.Mesh(ringGeo, ringMat);
            ring.rotation.x = Math.PI / 2;
            ring.position.z = -1.8;
            scene.add(ring);
            
            camera.position.z = 4.5;
            camera.position.y = 0.5;
            
            // Store objects for animation
            window._3dObjects = { knot, ring, particleSystem };
        }
        
        function animate3D() {
            requestAnimationFrame(animate3D);
            if (window._3dObjects) {
                window._3dObjects.knot.rotation.x += 0.003;
                window._3dObjects.knot.rotation.y += 0.005;
                window._3dObjects.ring.rotation.z += 0.002;
                window._3dObjects.ring.rotation.y += 0.001;
                particleSystem.rotation.y += 0.0008;
                particleSystem.rotation.x = Math.sin(Date.now() * 0.0003) * 0.1;
            }
            renderer.render(scene, camera);
        }
        
        init3D();
        animate3D();
        
        // handle resize
        window.addEventListener('resize', onWindowResize, false);
        function onWindowResize() {
            camera.aspect = window.innerWidth / window.innerHeight;
            camera.updateProjectionMatrix();
            renderer.setSize(window.innerWidth, window.innerHeight);
            lCanvas.width = window.innerWidth;
            lCanvas.height = window.innerHeight;
        }
        
        // ========================
        // LIGHTNING / SPARK EFFECT (Enhanced electric arc)
        // ========================
        const lCanvas = document.getElementById('lightning-canvas');
        const ctx2d = lCanvas.getContext('2d');
        lCanvas.width = window.innerWidth;
        lCanvas.height = window.innerHeight;
        
        function drawLightningBolt(x, y) {
            ctx2d.clearRect(0, 0, lCanvas.width, lCanvas.height);
            // Multiple branches
            const branches = 6;
            for (let b = 0; b < branches; b++) {
                ctx2d.beginPath();
                ctx2d.strokeStyle = `rgba(0, 255, 80, ${0.4 + Math.random() * 0.5})`;
                ctx2d.lineWidth = 2 + Math.random() * 3;
                ctx2d.shadowBlur = 14;
                ctx2d.shadowColor = '#0f0';
                let startX = x + (Math.random() - 0.5) * 40;
                let startY = y + (Math.random() - 0.5) * 40;
                ctx2d.moveTo(startX, startY);
                let steps = 10 + Math.floor(Math.random() * 8);
                let currX = startX, currY = startY;
                for (let i = 0; i < steps; i++) {
                    let angle = (Math.random() - 0.5) * Math.PI * 0.7;
                    let len = 15 + Math.random() * 30;
                    let newX = currX + Math.cos(angle) * len * (Math.random() * 1.2);
                    let newY = currY + Math.sin(angle) * len + (Math.random() - 0.5) * 25;
                    ctx2d.lineTo(newX, newY);
                    currX = newX;
                    currY = newY;
                }
                ctx2d.stroke();
                
                // secondary mini sparks
                for (let s = 0; s < 4; s++) {
                    ctx2d.beginPath();
                    ctx2d.moveTo(currX, currY);
                    ctx2d.lineTo(currX + (Math.random() - 0.5) * 35, currY + (Math.random() - 0.5) * 35);
                    ctx2d.strokeStyle = '#ff4444';
                    ctx2d.lineWidth = 1.5;
                    ctx2d.stroke();
                }
            }
            setTimeout(() => {
                ctx2d.clearRect(0, 0, lCanvas.width, lCanvas.height);
            }, 130);
        }
        
        // event listeners for mouse/touch
        window.addEventListener('mousedown', (e) => drawLightningBolt(e.clientX, e.clientY));
        window.addEventListener('touchstart', (e) => {
            e.preventDefault(); // avoid zoom but allow scroll? small fix
            if (e.touches.length) drawLightningBolt(e.touches[0].clientX, e.touches[0].clientY);
